# Google AdSense
# Required for ads to show. Get this from your AdSense dashboard > Account > Settings > Account Information.
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-0000000000000000

# Ad Slot IDs
# Required for specific ad placements. Create these in AdSense > Ads > By ad unit.
# Format: XXXXXXXXXX (numeric ID)
NEXT_PUBLIC_AD_SLOT_SIDEBAR_TOP=0000000000
NEXT_PUBLIC_AD_SLOT_SIDEBAR_STICKY=0000000000
NEXT_PUBLIC_AD_SLOT_HOME_MID=0000000000
NEXT_PUBLIC_AD_SLOT_ARTICLE_TOP=0000000000
NEXT_PUBLIC_AD_SLOT_ARTICLE_BOTTOM=0000000000
NEXT_PUBLIC_AD_SLOT_CATEGORY_MID=0000000000

# Google Analytics 4
# Required for tracking. Get this from Analytics > Admin > Data Streams.
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console
# Optional but recommended for SEO. Get the verification code from the HTML tag verification method.
# Format: Random string from the content content="" part of the meta tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_string_here

# Mailchimp
# Required for newsletter signup forms to work.
# Go to Audience > Signup forms > Embedded forms > Continue > Copy the action URL from the code (starts with https://... and ends with ...subscribe/post?u=...&id=...)
# Format: https://yourdomain.usX.list-manage.com/subscribe/post?u=XXXXXXXXXXXXXXXX&id=XXXXXXXXXX
NEXT_PUBLIC_MAILCHIMP_URL=https://example.us1.list-manage.com/subscribe/post?u=xxxxxxxxxxxxxxxxx&id=xxxxxxxxx

# Disqus Comments
# Optional. Required if you want comments on articles.
# Get this from Disqus Admin > Settings > General > Shortname.
# Format: your-site-shortname
NEXT_PUBLIC_DISQUS_SHORTNAME=lifewise-demo

# Site URL
# Required for SEO canonical tags and sitemap generation.
# Format: https://yourdomain.com (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://lifewise.com
